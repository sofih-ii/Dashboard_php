# ============================================================
#  Laravel .gitignore
#  NO subir estos archivos al repositorio
# ============================================================

# ── Variables de entorno (¡MUY SENSIBLE!) ───────────────────
# Contiene contraseñas de BD, API keys, APP_KEY, etc.
.env
.env.backup
.env.production
.env.staging

# ── Dependencias (se reinstalan con composer install) ────────
/vendor/

# ── Cache y archivos generados por Laravel ──────────────────
/bootstrap/cache/*.php
/storage/*.key

# ── Logs de la aplicación ────────────────────────────────────
/storage/logs/*.log

# ── Archivos de sesión y caché ───────────────────────────────
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*

# ── Archivos subidos por usuarios ────────────────────────────
/storage/app/public/*
!/storage/app/public/.gitkeep

# ── Node modules (si se usa Vite/npm) ────────────────────────
/node_modules/
npm-debug.log
yarn-error.log

# ── Assets compilados por Vite ────────────────────────────────
/public/build/
/public/hot
/public/storage

# ── Archivos del sistema operativo ──────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDEs y editores ──────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.phpstorm.meta.php
_ide_helper.php
_ide_helper_models.php
.php_cs.cache
.php-cs-fixer.cache

# ── PHPUnit y testing ────────────────────────────────────────
/coverage/
.phpunit.result.cache
phpunit.xml

# ── Archivos de Composer lock (opcional mantenerlo) ──────────
# composer.lock  # <-- NO ignorar, es buena práctica subirlo

# ── Archivos temporales ──────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig

# ── Certificados SSL locales ─────────────────────────────────
*.pem
*.key
*.crt
*.p12

# ── Docker (si se usa) ───────────────────────────────────────
docker-compose.override.yml
.docker/

# ── Archivos de Homestead/Valet ──────────────────────────────
Homestead.yaml
Homestead.json
auth.json